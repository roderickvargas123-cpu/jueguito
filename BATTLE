if getgenv().AuraDiagnosticoV4 then 
    print("[!] El script ya estaba inyectado. Cambia de servidor para reiniciar.")
    return 
end
getgenv().AuraDiagnosticoV4 = true

print("[1] Iniciando inyección. Cargando servicios...")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

-- ==========================================
-- CONFIGURACIÓN DEL SISTEMA
-- ==========================================
local expanderActivado = false 
local tamañoMasivo = Vector3.new(15, 15, 15)
local tamañoNormal = Vector3.new(2, 2, 1)

local rangoDePeligro = 12 
local cooldownAtaque = 0.3 
local ejecutandoAtaque = false

print("[2] Servicios listos. Construyendo Interfaz...")
-- ==========================================
-- INTERFAZ GRÁFICA
-- ==========================================
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "AuraGUI_V4"
screenGui.ResetOnSpawn = false 

-- Evitamos el WaitForChild para que el inyector no se congele
local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
if playerGui then
    screenGui.Parent = playerGui
    print("[3] UI asignada a PlayerGui con éxito.")
else
    print("[ERROR] No se encontró PlayerGui. El inyector está cargando demasiado rápido.")
end

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 220, 0, 70)
frame.Position = UDim2.new(0.02, 0, 0.05, 0)
frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
frame.BorderSizePixel = 2
frame.BorderColor3 = Color3.fromRGB(255, 0, 0) 
frame.Parent = screenGui

local textLabel = Instance.new("TextLabel")
textLabel.Size = UDim2.new(1, 0, 0, 40)
textLabel.BackgroundTransparency = 1
textLabel.Text = "[ EXPANSIÓN: APAGADA ]"
textLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
textLabel.Font = Enum.Font.Code
textLabel.TextSize = 13
textLabel.Parent = frame

local hideLabel = Instance.new("TextLabel")
hideLabel.Size = UDim2.new(1, 0, 0, 20)
hideLabel.Position = UDim2.new(0, 0, 0, 40)
hideLabel.BackgroundTransparency = 1
hideLabel.Text = "[INSERT] para Ocultar Menú"
hideLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
hideLabel.Font = Enum.Font.SourceSans
hideLabel.TextSize = 14
hideLabel.Parent = frame

print("[4] Configurando controles de teclado...")
-- ==========================================
-- CONTROL DE TECLAS (TOGGLE E INSERT)
-- ==========================================
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Insert then
        screenGui.Enabled = not screenGui.Enabled
    end

    if not gameProcessed and input.KeyCode == Enum.KeyCode.P then
        expanderActivado = not expanderActivado 
        
        if expanderActivado then
            frame.BorderColor3 = Color3.fromRGB(0, 255, 0)
            textLabel.TextColor3 = Color3.fromRGB(0, 255, 0)
            textLabel.Text = "[ EXPANSIÓN: ENCENDIDA ]"
            print("[+] Expansión activada")
        else
            frame.BorderColor3 = Color3.fromRGB(255, 0, 0)
            textLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
            textLabel.Text = "[ EXPANSIÓN: APAGADA ]"
            print("[-] Expansión desactivada")
        end
    end
end)

-- ==========================================
-- FUNCIÓN DE GATILLO AUTOMÁTICO
-- ==========================================
local function EjecutarAutoHit(arma)
    if ejecutandoAtaque then return end
    ejecutandoAtaque = true
    
    arma:Activate()
    
    task.delay(cooldownAtaque, function()
        ejecutandoAtaque = false
    end)
end

print("[5] Iniciando motor de combate y escáner...")
-- ==========================================
-- EL MOTOR PRINCIPAL (RenderStepped)
-- ==========================================
RunService.RenderStepped:Connect(function()
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    
    local miPosicion = LocalPlayer.Character.HumanoidRootPart.Position
    local armaEquipada = LocalPlayer.Character:FindFirstChildOfClass("Tool")
    
    for _, jugador in ipairs(Players:GetPlayers()) do
        if jugador ~= LocalPlayer and jugador.Character and jugador.Character:FindFirstChild("HumanoidRootPart") then
            
            local rootPart = jugador.Character.HumanoidRootPart
            
            if armaEquipada then
                local distancia = (miPosicion - rootPart.Position).Magnitude
                if distancia <= rangoDePeligro then
                    EjecutarAutoHit(armaEquipada)
                end
            end

            if expanderActivado then
                rootPart.Size = tamañoMasivo
                rootPart.Transparency = 0.7 
                rootPart.CanCollide = false
            else
                rootPart.Size = tamañoNormal
                rootPart.Transparency = 1
            end
            
        end
    end
end)

print("[6] ¡Inyección completada con éxito! Listo para usar.")
